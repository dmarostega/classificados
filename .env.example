APP_NAME="Classificados"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rockclassifields
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
MEDIA_DISK=public
PUBLIC_STORAGE_URL=/storage
MEDIA_MAX_SIZE_KB=10240
MEDIA_IMAGE_MAX_WIDTH=2400
MEDIA_IMAGE_QUALITY=82

MAIL_MAILER=log
MAIL_FROM_ADDRESS="admin@rockcodelabs.com.br"
MAIL_FROM_NAME="${APP_NAME}"

SEO_DEFAULT_TITLE="${APP_NAME}"
SEO_TITLE_SUFFIX=" | ${APP_NAME}"
SEO_DEFAULT_DESCRIPTION="Classificados para publicar, gerenciar e encontrar anuncios locais."
SEO_DEFAULT_IMAGE=
SEO_TWITTER_CARD=summary_large_image

GROWTH_ENABLED=false
GROWTH_RETENTION_DAYS=365
VITE_APP_NAME="${APP_NAME}"
VITE_GROWTH_ENABLED="${GROWTH_ENABLED}"
